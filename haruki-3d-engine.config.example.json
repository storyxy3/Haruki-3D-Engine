{
  "capture": {
    "runtimeRoot": "/data/runtime",
    "outputDir": "/data/captures",
    "width": 1400,
    "height": 1000,
    "scale": 2,
    "timeoutMs": 45000,
    "phase": 0.5,
    "clip": "motion_loop",
    "warmupFrames": 60,
    "warmupMode": "animation",
    "springRuntimeMode": "unity-prefab",
    "cameraPreset": "capture",
    "tempTtl": "6h",
    "tempMaxBytes": "5GB",
    "gcInterval": "1h"
  },
  "chromium": {
    "executable": "chromium"
  },
  "server": {
    "port": 8080
  }
}
